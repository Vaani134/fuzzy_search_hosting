# Copy this file to .env and fill in your values
# Flask
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=change-me-in-production

# MySQL (source database)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cloudbbtl_novx

# SQLite path (leave blank to use default: db/local.db)
SQLITE_PATH=

# Redis (optional — leave blank to use in-memory cache)
# When set, search results are cached in Redis instead of a Python dict.
# Falls back to in-memory automatically if Redis is unreachable.
# Format: redis://[password@]host:port/db  or  rediss:// for TLS
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=fzsearch:
