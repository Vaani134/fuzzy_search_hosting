# =============================================================================
# Fuzzy Search Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values for your deployment.
# DO NOT commit .env to git — add it to .gitignore

# ─────────────────────────────────────────────────────────────────────────────
# Flask Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Environment: 'production' or 'development'
# In production, DEBUG is False; in development, DEBUG is True
FLASK_ENV=development

# Secret key for session/cookie encryption (REQUIRED FOR PRODUCTION)
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-key-change-in-production

# Host and port for Flask development server (not used with Gunicorn)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ─────────────────────────────────────────────────────────────────────────────
# MySQL Configuration (Data Source)
# ─────────────────────────────────────────────────────────────────────────────

# MySQL credentials for syncing product data
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cloudbbtl_novx

# ─────────────────────────────────────────────────────────────────────────────
# SQLite Configuration (Local Cache)
# ─────────────────────────────────────────────────────────────────────────────

# Optional: path to SQLite database (defaults to db/local.db)
# Leave blank to use default
SQLITE_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration (Optional Caching Layer)
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL (optional)
# Leave blank to use in-memory cache instead
# Examples:
#   redis://localhost:6379/0
#   redis://user:password@redis.example.com:6379/0
#   redis://:password@localhost:6379/0
REDIS_URL=

# Redis key prefix for namespacing cache entries
REDIS_KEY_PREFIX=fzsearch:

# ─────────────────────────────────────────────────────────────────────────────
# Image CDN Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for product images stored in the database
# DB stores relative paths like /img/product.jpg
# This URL is prepended to create full URLs
IMAGE_BASE_URL=https://novxcloud.com

# ─────────────────────────────────────────────────────────────────────────────
# Deployment Notes
# ─────────────────────────────────────────────────────────────────────────────

# For Render deployment:
#   1. Set FLASK_ENV=production
#   2. Generate a strong SECRET_KEY and set it
#   3. Set MySQL credentials to point to your production database
#   4. (Optional) Configure Redis URL for distributed caching
#   5. Render will use the Procfile to start with Gunicorn

# For local development:
#   1. Leave FLASK_ENV=development
#   2. Fill in local MySQL credentials
#   3. Leave REDIS_URL blank (uses in-memory cache)
#   4. Run: python app.py

# For testing without MySQL:
#   1. Ensure SQLite db/local.db exists with sample data
#   2. Set MYSQL_HOST to an invalid address to prevent connection attempts

